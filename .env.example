# Skopiuj ten plik jako `.env` w głównym katalogu projektu i uzupełnij wartości.
# NIE commituj pliku `.env` — jest w .gitignore.

# ── Resend (wysyłka maili z formularza) ─────────────────────────────────────
# Hasła do Gmaila / konta pocztowego NIE wklejasz tutaj.
# Jedyny sekret to klucz API z panelu: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Na jaki adres mają wpadać wiadomości z formularza (domyślnie poniżej).
CONTACT_TO_EMAIL=wykonczenia.ddbud@gmail.com

# Nadawca widoczny w skrzynce. Na testy bez własnej domeny możesz użyć:
#   DD BUD <onboarding@resend.dev>
# Po zweryfikowaniu domeny w Resend ustaw np.: DD BUD <kontakt@twojadomena.pl>
CONTACT_FROM_EMAIL=DD BUD <onboarding@resend.dev>

# Port API (npm run server)
PORT=3001

# Opcjonalnie: front na produkcji (oddziel przecinkiem). Przy jednym deployu (Railway/Render)
# front i API mają ten sam origin — zwykle NIE ustawiasz CORS.
# CORS_ORIGINS=https://twojadomena.pl

# ── Hosting (Railway / Render / Docker) ─────────────────────────────────────
# PORT ustawia platforma. NODE_ENV=production ustawiają Render / Docker lub panel.
# Na Railway statyczny front z dist włącza się automatycznie (zmienna RAILWAY_ENVIRONMENT).

# ── Front (build / GitHub Pages) — tylko zmienne VITE_* ─────────────────────
# Pełny URL do POST formularza, gdy strona jest na GitHub Pages, a backend gdzie indziej (np. Railway).
# W GitHub: Settings → Secrets and variables → Actions → Variables → VITE_CONTACT_API
# Przykład: https://twoj-backend.up.railway.app/api/contact
# VITE_CONTACT_API=

# Lokalny test buildu jak na Pages: VITE_BASE_PATH=/nazwa-repo/ npm run build
# VITE_BASE_PATH=
