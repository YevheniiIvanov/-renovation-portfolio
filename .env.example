# Skopiuj ten plik jako `.env` w głównym katalogu projektu i uzupełnij wartości.
# NIE commituj pliku `.env` — jest w .gitignore.

# ── Resend (wysyłka maili z formularza) ─────────────────────────────────────
# Hasła do Gmaila / konta pocztowego NIE wklejasz tutaj.
# Jedyny sekret to klucz API z panelu: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Na jaki adres mają wpadać wiadomości z formularza (domyślnie poniżej).
CONTACT_TO_EMAIL=wykonczenia.ddbud@gmail.com

# Nadawca widoczny w skrzynce. Na testy bez własnej domeny możesz użyć:
#   DD BUD <onboarding@resend.dev>
# Po zweryfikowaniu domeny w Resend ustaw np.: DD BUD <kontakt@twojadomena.pl>
CONTACT_FROM_EMAIL=DD BUD <onboarding@resend.dev>

# Port API (npm run server)
PORT=3001

# Opcjonalnie: front na produkcji (oddziel przecinkiem, bez spacji wokół przecinka).
# Przykład: https://twojadomena.pl,https://www.twojadomena.pl
# Lokalnie (Vite) działa bez tego — domyślnie dozwolone są localhost:5173.
# CORS_ORIGINS=https://twojadomena.pl
